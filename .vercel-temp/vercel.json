{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/v1/(.*)",
      "headers": {
        "x-original-path": "/v1/$1"
      },
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "headers": {
        "x-original-path": "/api/$1"
      },
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "headers": {
        "x-original-path": "/$1"
      },
      "dest": "/api/index.js"
    }
  ]
}
