{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "/api/index.js?path=/v1/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js?path=/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js?path=/$1"
    }
  ]
}
